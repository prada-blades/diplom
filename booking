#!/bin/sh

set -eu

SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$DIR/$TARGET" ;;
  esac
done

PROJECT_DIR="$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
cd "$PROJECT_DIR"

usage() {
  cat <<'EOF'
Usage: booking <command>

Commands:
  up       Start postgres, redis, and app in Docker
  down     Stop the Docker services
  ps       Show service status
  logs     Follow server logs
  admin    Run the admin CLI in a one-off Docker container
  build    Rebuild the app image
EOF
}

if [ "${1:-}" = "" ]; then
  usage
  exit 1
fi

case "$1" in
  up)
    exec docker compose up -d postgres redis app
    ;;
  down)
    exec docker compose down
    ;;
  ps)
    exec docker compose ps
    ;;
  logs)
    exec docker compose logs -f app
    ;;
  admin)
    exec docker compose run --rm app admin
    ;;
  build)
    exec docker compose build app
    ;;
  *)
    usage
    exit 1
    ;;
esac
