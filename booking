#!/usr/bin/env sh

set -eu

usage() {
  cat <<'EOF'
Usage: ./booking <command>

Commands:
  init-env Create .env from .env.example and generate strong secrets
  up       Build and start app, postgres, and redis in the background
  restart  Rebuild and restart the app stack
  down     Stop and remove the app stack
  logs     Follow app logs in real time
EOF
}

ensure_env_file() {
  if [ -f .env ]; then
    return 0
  fi

  if [ ! -f .env.example ]; then
    echo ".env.example not found" >&2
    exit 1
  fi

  cp .env.example .env
}

generate_hex() {
  openssl rand -hex "$1"
}

get_env_value() {
  key="$1"
  file="$2"

  awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$file"
}

set_env_value() {
  key="$1"
  value="$2"
  file="$3"
  tmp_file="$(mktemp)"

  awk -v key="$key" -v value="$value" '
    BEGIN { updated = 0 }
    index($0, key "=") == 1 {
      print key "=" value
      updated = 1
      next
    }
    { print }
    END {
      if (updated == 0) {
        print key "=" value
      }
    }
  ' "$file" > "$tmp_file"

  mv "$tmp_file" "$file"
}

init_env() {
  ensure_env_file

  postgres_db="$(get_env_value POSTGRES_DB .env)"
  postgres_user="$(get_env_value POSTGRES_USER .env)"

  [ -n "$postgres_db" ] || postgres_db="diplom"
  [ -n "$postgres_user" ] || postgres_user="postgres"

  postgres_password="$(generate_hex 24)"
  jwt_secret="$(generate_hex 32)"
  admin_password="$(generate_hex 18)"
  database_url="postgres://${postgres_user}:${postgres_password}@postgres:5432/${postgres_db}?sslmode=disable"

  set_env_value POSTGRES_PASSWORD "$postgres_password" .env
  set_env_value APP_JWT_SECRET "$jwt_secret" .env
  set_env_value APP_ADMIN_PASSWORD "$admin_password" .env
  set_env_value APP_DATABASE_URL "$database_url" .env

  cat <<EOF
.env is ready.
POSTGRES_PASSWORD=$postgres_password
APP_ADMIN_PASSWORD=$admin_password
APP_JWT_SECRET=$jwt_secret
EOF
}

if [ $# -ne 1 ]; then
  usage
  exit 1
fi

case "$1" in
  init-env)
    init_env
    ;;
  up)
    exec docker compose up -d --build
    ;;
  restart)
    docker compose down
    exec docker compose up -d --build
    ;;
  down)
    exec docker compose down
    ;;
  logs)
    exec docker compose logs -f app
    ;;
  *)
    usage
    exit 1
    ;;
esac
